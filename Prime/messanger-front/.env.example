# ============================================
# Prime Messenger Frontend Configuration
# ============================================
# Скопируйте этот файл в .env.local и заполните значениями

# API URL Backend
# Для локальной разработки:
VITE_API_URL=http://localhost:4000

# Для работы в сети (требуется HTTPS для уведомлений):
# VITE_API_URL=https://192.168.0.233:4001

# Для продакшена:
# VITE_API_URL=https://your-domain.com
